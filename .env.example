# ── University credentials ────────────────────────────────────────────────────
KU_USERNAME=your_university_username
KU_PASSWORD=your_university_password

# ── Google OAuth2 (run `npm run setup` to obtain these) ───────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ── Optional settings ─────────────────────────────────────────────────────────
# Google Calendar to write to (default: primary)
GOOGLE_CALENDAR_ID=primary

# Timezone used for date formatting and calendar events (default: Europe/Vilnius)
TIMEZONE=Europe/Vilnius

# How often to sync in minutes (default: 60)
SYNC_INTERVAL_MINUTES=60

# Log verbosity: error | warn | info | debug (default: info)
LOG_LEVEL=info
